@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}
@model Gorev
<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card shadow p-4">
                <h3 class="card-title text-center mb-4">Görev Detayı</h3>

                <!-- Görev Başlığı -->
                <div class="mb-3">
                    <label class="form-label"><strong>Görev Başlığı:</strong></label>
                    <p class="form-control-plaintext">@Model.Baslik</p>
                </div>

                <!-- Görev Açıklaması -->
                <div class="mb-3">
                    <label class="form-label"><strong>Görev Açıklaması:</strong></label>
                    <p class="form-control-plaintext">
                        @Model.Aciklama
                    </p>
                </div>

                <!-- Personel Bilgisi -->
                <div class="mb-3">
                    <label class="form-label"><strong>Görevi Alan Personel:</strong></label>
                    <p class="form-control-plaintext"> @Model.Kim.Ad - @Model.Kim.Soyad</p>
                </div>
                <div class="mb-3">
                    <label class="form-label"><strong>Çalışan Açıklaması:</strong></label>
                    <p class="form-control-plaintext">
                        @Model.CalisanAciklama
                    </p>
                </div>
                <!-- Durum -->
                <div class="mb-4">
                    <label class="form-label"><strong>Durum:</strong></label><br>
                    <button class="btn btn-outline-success" disabled>
                        <i class="bi bi-check-circle"></i> Tamamlandı
                    </button>
                </div>

                <!-- Butonlar -->
                <div class="d-flex justify-content-end">
                    <a href="/admin/gorevler" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Geri Dön
                    </a>
                </div>

            </div>
        </div>
    </div>
</div>