@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}
@model List<Gorev>
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">

<div class="container mt-5">
    <h3 class="mb-4">Verilen Görevler</h3>

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-body d-flex align-items-center justify-content-between">
                        <div>
                            <h5 class="card-title mb-1">@item.Baslik</h5>
                            <p class="card-text mb-0"><strong>Verilen Kişi:</strong>@item.Kim.Ad</p>
                        </div>

                        <div>
                            @if(item.Durum=="Teslim Edildi")
                            {
                                <a href="/admin/GorevDetay/@item.Id" class="btn btn-primary "> Detaylar</a>

                            }
                            <button class="btn @(item.Durum == "Bekliyor" ? "btn-outline-primary" : item.Durum == "Teslim Edildi" ? "btn-outline-success" :item.Durum=="Çalışıyor"? "btn-outline-warning":"") " disabled>
                                <i class="bi @(item.Durum == "Bekliyor" ? "bi-clock-history" : item.Durum == "Teslim Edildi" ? "bi-check-circle" :item.Durum=="Çalışıyor"? "bi-hourglass-split":"")"></i> @item.Durum
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
        <!-- Görev Kartı -->
        


    </div>
</div>
@section Scripts
{

    @if (TempData["basarili"] != null)
    {
        <script>

            Swal.fire({
                title: "Başarılı",
                text: "@Html.Raw(TempData["basarili"])",
                icon: "success"
            });
        </script>
    }
    @if (TempData["uyari"] != null)
    {
        <script>

            Swal.fire({
                title: "Uyarı",
                text: "@Html.Raw(TempData["uyari"])",
                icon: "warning"
            });
        </script>
    }

}