@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}
@model List<Calisan>
<div class="container mt-4">

    <!-- ÇALIŞAN EKLE BUTONU (TAM SATIR) -->
    <div class="row mb-4">
        <div class="col-12">
            <a href="/admin/calisanekle" class="btn btn-success w-100 d-flex align-items-center justify-content-center">
                <i class="bi bi-plus-circle me-2"></i> Çalışan Ekle
            </a>
        </div>
    </div>

    <!-- ÇALIŞAN KARTLARI (TAM SATIR) -->
    <div class="row g-3">

        @foreach (var item in Model)
        {
            <div class="col-12">
                <div class="card h-100 shadow-sm">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="card-title mb-1">@item.Ad @item.Soyad</h5>
                            <p class="card-text mb-0"><strong>Departman:@item.Departman.Isim</strong></p>
                            <p class="card-text mb-0">Başlangıç Tarihi:@item.Baslangic</p>
                        </div>
                    </div>
                </div>
            </div>
        }

    </div>

</div>