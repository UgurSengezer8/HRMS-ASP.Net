@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}
@model List<Departman>
<div class="container mt-4">

    <!-- DEPARTMAN EKLEME ALANI -->
    <div class="card p-4 mb-4">
        <h5 class="mb-3">Departman Ekle</h5>
        <form asp-action="departman" method="post">
            <div class="row g-2">
                <div class="col-12 col-md-8">
                    <input type="text" name="ad" class="form-control" placeholder="Departman Adı Giriniz" required>
                </div>
                <div class="col-12 col-md-4">
                    <input type="submit" class="btn btn-success w-100" value="Departman Ekle">
                </div>
            </div>
        </form>
        
    </div>

    <!-- DEPARTMANLARIN GÖSTERİLDİĞİ KARTLAR -->
    <div class="row g-3">
        @foreach (var item in Model)
        {
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card d-flex flex-row align-items-center justify-content-between p-3">
                    <span class="fw-bold">@item.Isim</span>
                    <a href="/admin/departmansil/@item.Id" class="btn btn-danger btn-sm"><i class="bi bi-trash"></i> Sil</a>
                </div>
            </div>
        }
        <!-- Örnek Departman Kartı -->
        

        <!-- İstersen buraya daha fazla departman kartı ekleyebilirsin -->

    </div>

</div>
@section Scripts
{

    @if (TempData["basarili"] != null)
    {
        <script>

            Swal.fire({
                title: "Başarılı",
                text: "@Html.Raw(TempData["basarili"])",
                icon: "success"
            });
        </script>
    }
    @if (TempData["uyari"] != null)
    {
        <script>

            Swal.fire({
                title: "Uyarı",
                text: "@Html.Raw(TempData["uyari"])",
                icon: "warning"
            });
        </script>
    }

}
