@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@model ProfilViewModel
<div class="profile-card col-6 ms-2">
    <form asp-controller="Account" method="post" enctype="multipart/form-data">
    <div class="form-group">
        <label asp-for="KullaniciAdi"></label>
        <input asp-for="KullaniciAdi" class="form-control" required/>
        <span asp-validation-for="KullaniciAdi" class="text-danger"></span>
    </div>
        <div class="form-group">
            <label asp-for="EskiSifre"></label>
            <input asp-for="EskiSifre" class="form-control" required/>
            <span asp-validation-for="EskiSifre" class="text-danger"></span>
        </div>
    <div class="form-group">
        <label asp-for="Sifre"></label>
        <input asp-for="Sifre" class="form-control" required/>
        <span asp-validation-for="Sifre" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Adres"></label>
        <input asp-for="Adres" class="form-control" required/>
        <span asp-validation-for="Adres" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Telefon"></label>
        <input asp-for="Telefon" class="form-control" required/>
        <span asp-validation-for="Telefon" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Resim"></label>
        <input asp-for="Resim" class="form-control" required/>
        <span asp-validation-for="Resim" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-warning w-100 mt-3">Profili Güncelle</button>
    </form>
</div>
@section Scripts
{

    @if (TempData["basarili"] != null)
    {
        <script>

            Swal.fire({
                title: "Basarili",
                text: "@Html.Raw(TempData["basarili"])",
                icon: "success"
            });
        </script>
    }
    @if (TempData["hata"] != null)
    {
        <script>

            Swal.fire({
                title: "Hatali",
                text: "@Html.Raw(TempData["hata"])",
                icon: "error"
            });
        </script>
    }

}